{
    "name": "jigar-tecmantras/laravel-ecommerce-platform",
    "type": "project",
    "description": "Scalable Laravel ecommerce backend with REST APIs, analytics hooks, and notification integrations.",
    "require": {
        "php": "^8.1",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^3.4"
    },
    "require-dev": {
        "fakerphp/faker": "^1.18",
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.7"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate"
        ]
    }
}
